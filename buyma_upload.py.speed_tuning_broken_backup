    if s in {'XL', 'XXL', 'XXXL'}:
        return 'XL餓δ툓'

    # ?レ옄 ?쒓린 ?뺢퇋?? 215 -> 21.5, 250 -> 25.0, 25 -> 25
    only_num = re.sub(r"[^0-9.]", "", s)
    if only_num:
        try:
            if '.' in only_num:
