def read_upload_rows(service, sheet_name: str, specific_row: int = 0) -> List[Dict[str, str]]:
    """Read upload target rows from sheet. Only rows with BUYMA price are included."""
    try:
        result = service.spreadsheets().values().get(
            spreadsheetId=SPREADSHEET_ID,
            range=f"'{sheet_name}'!A{ROW_START}:O1000",
        ).execute()
    except Exception as e:
        print(f"?쒗듃 ?쎄린 ?ㅽ뙣: {e}")
        return []

    rows_data = []
    for idx, row in enumerate(result.get('values', []), start=ROW_START):
        if specific_row and idx != specific_row:
            continue

        def cell(col_letter: str) -> str:
            i = COL[col_letter]
            return row[i].strip() if i < len(row) and row[i] else ""

        # 理쒖냼 議곌굔: URL + ?곹뭹紐?+ 諛붿씠留??먮ℓ媛媛 ?덉뼱??異쒗뭹 媛??
        url = cell('B')
        product_name = cell('E')
        buyma_price = cell('L')

        if not url or not product_name or not buyma_price:
            continue

        # O?댁뿉 媛믪씠 ?덉쑝硫??대? ?낅줈???꾨즺濡?媛꾩＜ ???앸왂
        if cell('O'):
            print(f"  {idx}??嫄대꼫? (O???꾨즺 ?쒖떆: {cell('O')})")
            continue

        rows_data.append({
            'row_num': idx,
            'url': url,
            'brand': cell('C'),
            'brand_en': cell('D'),
            'product_name_kr': product_name,
            'product_name_en': cell('F'),
            'musinsa_sku': cell('G'),
            'color_kr': cell('H'),
            'color_en': cell('I'),
            'size': cell('J'),
            'price_krw': cell('K'),
            'buyma_price': buyma_price,
            'image_paths': cell('M'),
            'shipping_cost': cell('N'),
        })

    return rows_data


