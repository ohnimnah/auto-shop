            if len(rows) >= len(sizes):
                break
            add_links = panel.find_elements(By.XPATH, ".//div[contains(@class,'bmm-c-form-table__foot')]//a")
            clicked = False
            for a in add_links:
                txt = (a.text or '').strip()
                if '?겹걮?꾠궢?ㅳ궨?믦옙?? in txt or '?듐궎?? in txt:
