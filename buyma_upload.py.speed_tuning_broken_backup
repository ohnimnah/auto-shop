def _split_color_values(color_text: str) -> List[str]:
    """?됱긽 臾몄옄?댁쓣 援щ텇??湲곗??쇰줈 遺꾨━?쒕떎."""
    if not color_text:
        return []
    parts = re.split(r'[,/|]|\s+and\s+|\s*&\s*', color_text)
    out = []
    for p in parts:
        v = p.strip()
        if v:
            out.append(v)
    return out


