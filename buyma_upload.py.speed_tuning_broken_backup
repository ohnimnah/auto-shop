def _get_category_select_el(driver, item_index: int):
    """item_index???대떦?섎뒗 React-Select ?붿냼瑜?諛섑솚?쒕떎."""
    if item_index == 0:
        return driver.find_element(By.CSS_SELECTOR, '.sell-category-select')
